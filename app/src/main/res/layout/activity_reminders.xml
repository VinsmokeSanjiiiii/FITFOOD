<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF5722"
        android:padding="20dp"
        android:elevation="4dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Meal Reminders"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                app:tint="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvNextReminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next: Lunch at 12:00 PM"
            android:textColor="#FFCCBC"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/item_reminder_card" android:id="@+id/cardBreakfast"/>

            <include layout="@layout/item_reminder_card" android:id="@+id/cardLunch"/>

            <include layout="@layout/item_reminder_card" android:id="@+id/cardSnacks"/>

            <include layout="@layout/item_reminder_card" android:id="@+id/cardDinner"/>

            <Button
                android:id="@+id/btnSaveReminders"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save &amp; Sync Changes"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:elevation="2dp"
                android:background="@drawable/btn3"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Note: Reminders will not ring if you have already logged the meal for the day."
                android:gravity="center"
                android:textColor="#757575"
                android:textSize="12sp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>