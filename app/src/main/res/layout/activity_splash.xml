<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FFF3E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/fitfood_logo"
            android:contentDescription="FitFood Logo"
            android:layout_marginBottom="24dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/overviewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/overviewTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to FITFOOD"
                    android:textColor="#FF5722"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:layout_gravity="center_horizontal"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/overviewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="FITFOOD helps adults aged 35+ manage nutrition, track calories, and reduce health risks. Start your journey today!"
                    android:textAlignment="center"
                    android:textColor="#424242"
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.2"
                    android:fontFamily="sans-serif" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:visibility="invisible"
                    android:layout_gravity="center_horizontal"
                    android:indeterminateTint="#FF5722"/>

                <Button
                    android:id="@+id/btnProceed"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/btn3"
                    android:backgroundTint="#FF5722"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:text="Get Started" />

                <Button
                    android:id="@+id/btnInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/btn3"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#FF5722"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:text="How to Use App"
                    style="?android:attr/borderlessButtonStyle"
                    android:elevation="0dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="#BDBDBD"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"/>

</RelativeLayout>