<resources>

    <!-- ✅ Green Button -->
    <style name="FitFoodGreenButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_rect_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">12dp</item>
        <item name="android:backgroundTint">@null</item> <!-- important -->
    </style>

    <!-- ✅ Orange Button (optional, only if needed) -->
    <style name="FitFoodOrangeButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_rect_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">12dp</item>
        <item name="android:backgroundTint">@null</item>
    </style>

</resources>
