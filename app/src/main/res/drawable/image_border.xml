<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- background puti -->
    <solid android:color="@android:color/white" />

    <!-- border stroke -->
    <stroke
        android:width="2dp"
        android:color="@android:color/black" />

    <!-- konting round corner -->
    <corners android:radius="8dp" />

    <!-- para may space yung picture sa border -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
